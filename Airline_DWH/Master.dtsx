    <DTS:Executable
      DTS:refId="Package\SQL_ETL_Complete"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{EE000008-0000-4000-8000-EE0000000001}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_ETL_Complete"
      DTS:TaskContact="Execute SQL Task"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{EE000001-0000-4000-8000-EE0000000001}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;IF OBJECT_ID(N'etl.run_log') IS NOT NULL&#xA;BEGIN&#xA;    DECLARE @stgSat INT,@stgAct INT,@stgCust INT,@stgDate INT,@fSat INT,@fAct INT;&#xA;    SELECT @stgSat=COUNT(*) FROM dbo.stg_airline_satisfaction;&#xA;    SELECT @stgAct=COUNT(*) FROM dbo.stg_flight_activity;&#xA;    SELECT @stgCust=COUNT(*) FROM dbo.stg_customer_loyalty;&#xA;    SELECT @stgDate=COUNT(*) FROM dbo.stg_date;&#xA;    SELECT @fSat=COUNT(*) FROM [DWH_DB].[dbo].[FACT_PASSENGER_SATISFACTION];&#xA;    SELECT @fAct=COUNT(*) FROM [DWH_DB].[dbo].[FACT_FLIGHT_ACTIVITY];&#xA;    UPDATE etl.run_log&#xA;    SET ended_at=GETDATE(), status=N'Completed',&#xA;        stg_satisfaction=@stgSat, stg_loyalty=@stgAct,&#xA;        stg_customer=@stgCust, stg_date=@stgDate,&#xA;        fact_satisfaction=@fSat, fact_activity=@fAct,&#xA;        dim_summary=CONCAT(&#xA;            N'DIM_DATE:',(SELECT COUNT(*) FROM [DWH_DB].[dbo].[DIM_DATE] WHERE SK_Date &gt; 0),&#xA;            N' DIM_LOYALTY_CARD:',(SELECT COUNT(*) FROM [DWH_DB].[dbo].[DIM_LOYALTY_CARD] WHERE SK_LoyaltyCard &gt; 0),&#xA;            N' DIM_GEOGRAPHY:',(SELECT COUNT(*) FROM [DWH_DB].[dbo].[DIM_GEOGRAPHY] WHERE SK_Geography &gt; 0),&#xA;            N' DIM_CUSTOMER:',(SELECT COUNT(*) FROM [DWH_DB].[dbo].[DIM_CUSTOMER] WHERE SK_Customer &gt; 0),&#xA;            N' DIM_TRAVEL:',(SELECT COUNT(*) FROM [DWH_DB].[dbo].[DIM_TRAVEL] WHERE SK_Travel &gt; 0))&#xA;    WHERE run_id=(SELECT MAX(run_id) FROM etl.run_log WHERE status=N'Running');&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_ETL_Start"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{EE000002-0000-4000-8000-EE0000000001}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_ETL_Start"
      DTS:TaskContact="Execute SQL Task"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{EE000001-0000-4000-8000-EE0000000001}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;IF OBJECT_ID(N'etl.run_log') IS NOT NULL&#xA;    INSERT INTO etl.run_log (started_at,status) VALUES (GETDATE(),N'Running');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
