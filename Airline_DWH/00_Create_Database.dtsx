  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\SQL_Create_DWH_DB"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{AA000003-0000-4000-8000-AA0000000001}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Create_DWH_DB"
      DTS:TaskContact="Execute SQL Task"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AA000001-0000-4000-8000-AA0000000001}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;IF NOT EXISTS (SELECT 1 FROM sys.databases WHERE name=N'DWH_DB')&#xA;    CREATE DATABASE [DWH_DB];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Create_DWH_Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{AA000004-0000-4000-8000-AA0000000001}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Create_DWH_Tables"
      DTS:TaskContact="Execute SQL Task"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AA000001-0000-4000-8000-AA0000000001}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;USE [DWH_DB];&#xA;IF OBJECT_ID(N'dbo.FACT_FLIGHT_ACTIVITY') IS NOT NULL DROP TABLE dbo.FACT_FLIGHT_ACTIVITY;&#xA;IF OBJECT_ID(N'dbo.FACT_PASSENGER_SATISFACTION') IS NOT NULL DROP TABLE dbo.FACT_PASSENGER_SATISFACTION;&#xA;IF OBJECT_ID(N'dbo.DIM_CUSTOMER') IS NOT NULL DROP TABLE dbo.DIM_CUSTOMER;&#xA;IF OBJECT_ID(N'dbo.DIM_TRAVEL') IS NOT NULL DROP TABLE dbo.DIM_TRAVEL;&#xA;IF OBJECT_ID(N'dbo.DIM_GEOGRAPHY') IS NOT NULL DROP TABLE dbo.DIM_GEOGRAPHY;&#xA;IF OBJECT_ID(N'dbo.DIM_LOYALTY_CARD') IS NOT NULL DROP TABLE dbo.DIM_LOYALTY_CARD;&#xA;IF OBJECT_ID(N'dbo.DIM_DATE') IS NOT NULL DROP TABLE dbo.DIM_DATE;&#xA;CREATE TABLE dbo.DIM_DATE (&#xA;    SK_Date INT IDENTITY(1,1) PRIMARY KEY,&#xA;    DateValue DATE, Year INT, Quarter INT, QuarterLabel NVARCHAR(20),&#xA;    MonthNumber INT, MonthName NVARCHAR(20), DayOfWeek INT, DayName NVARCHAR(20),&#xA;    IsWeekend BIT, StartOfYear DATE, StartOfQuarter DATE, StartOfMonth DATE&#xA;);&#xA;CREATE TABLE dbo.DIM_LOYALTY_CARD (&#xA;    SK_LoyaltyCard INT IDENTITY(1,1) PRIMARY KEY,&#xA;    LoyaltyCard NVARCHAR(50) NOT NULL&#xA;);&#xA;CREATE TABLE dbo.DIM_GEOGRAPHY (&#xA;    SK_Geography INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Country NVARCHAR(100), Province NVARCHAR(100), City NVARCHAR(100), PostalCode NVARCHAR(20)&#xA;);&#xA;CREATE TABLE dbo.DIM_TRAVEL (&#xA;    SK_Travel INT IDENTITY(1,1) PRIMARY KEY,&#xA;    TypeOfTravel NVARCHAR(50), Class NVARCHAR(50), TravelProfile NVARCHAR(100)&#xA;);&#xA;CREATE TABLE dbo.DIM_CUSTOMER (&#xA;    SK_Customer INT IDENTITY(1,1) PRIMARY KEY,&#xA;    LoyaltyNumber NVARCHAR(50), Gender NVARCHAR(20), Education NVARCHAR(100),&#xA;    Salary NVARCHAR(50), MaritalStatus NVARCHAR(50), CLV DECIMAL(18,2),&#xA;    EnrollmentType NVARCHAR(50), EnrollmentYear INT, EnrollmentMonth INT,&#xA;    CancellationYear INT, CancellationMonth INT, IsChurned BIT,&#xA;    SK_LoyaltyCard INT, SK_Geography INT, EnrollmentDate DATE,&#xA;    SCD_StartDate DATE, SCD_EndDate DATE, SCD_IsCurrent BIT DEFAULT 1&#xA;);&#xA;CREATE TABLE dbo.FACT_PASSENGER_SATISFACTION (&#xA;    SK_Satisfaction INT IDENTITY(1,1) PRIMARY KEY,&#xA;    SK_Date INT DEFAULT -1, SK_Customer INT DEFAULT -1,&#xA;    SK_Travel INT DEFAULT -1, SK_Geography INT DEFAULT -1,&#xA;    Gender NVARCHAR(20), CustomerType NVARCHAR(50), Age INT,&#xA;    FlightDistance INT, DepartureDelay INT NULL, ArrivalDelay INT NULL,&#xA;    TimeConvenience INT, OnlineBooking INT, CheckinService INT,&#xA;    OnlineBoarding INT, GateLocation INT, OnboardService INT,&#xA;    SeatComfort INT, LegRoom INT, Cleanliness INT, FoodAndDrink INT,&#xA;    InFlightService INT, InFlightWifi INT, InFlightEntertainment INT,&#xA;    BaggageHandling INT, AvgServiceScore DECIMAL(5,2),&#xA;    Satisfaction NVARCHAR(50), Satisfaction_Flag BIT&#xA;);&#xA;CREATE TABLE dbo.FACT_FLIGHT_ACTIVITY (&#xA;    SK_Activity INT IDENTITY(1,1) PRIMARY KEY,&#xA;    SK_Customer INT DEFAULT -1, SK_Date INT DEFAULT -1,&#xA;    SK_LoyaltyCard INT DEFAULT -1, SK_Geography INT DEFAULT -1,&#xA;    TotalFlights INT, Distance DECIMAL(18,2),&#xA;    PointsAccumulated DECIMAL(18,2), PointsRedeemed DECIMAL(18,2),&#xA;    DollarCostPointsRedeemed DECIMAL(18,2)&#xA;);&#xA;USE [STAGING_DB];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Reset_Staging"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{AA000002-0000-4000-8000-AA0000000001}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Reset_Staging"
      DTS:TaskContact="Execute SQL Task"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AA000001-0000-4000-8000-AA0000000001}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;USE [STAGING_DB];&#xA;-- ETL audit schema&#xA;IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name=N'etl')&#xA;    EXEC sp_executesql N'CREATE SCHEMA etl';&#xA;IF OBJECT_ID(N'etl.run_log') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE etl.run_log (&#xA;        run_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        started_at DATETIME, ended_at DATETIME, status NVARCHAR(50),&#xA;        stg_satisfaction INT, stg_loyalty INT, stg_customer INT, stg_date INT,&#xA;        fact_satisfaction INT, fact_activity INT, dim_summary NVARCHAR(500)&#xA;    );&#xA;END;&#xA;-- Drop raw landing tables (created fresh each run by 01_Load_Staging)&#xA;IF OBJECT_ID(N'dbo.stg_raw_satisfaction') IS NOT NULL DROP TABLE dbo.stg_raw_satisfaction;&#xA;IF OBJECT_ID(N'dbo.stg_raw_flight_activity') IS NOT NULL DROP TABLE dbo.stg_raw_flight_activity;&#xA;IF OBJECT_ID(N'dbo.stg_raw_customer_loyalty') IS NOT NULL DROP TABLE dbo.stg_raw_customer_loyalty;&#xA;IF OBJECT_ID(N'dbo.stg_raw_date') IS NOT NULL DROP TABLE dbo.stg_raw_date;&#xA;-- Drop typed staging tables&#xA;IF OBJECT_ID(N'dbo.stg_airline_satisfaction') IS NOT NULL DROP TABLE dbo.stg_airline_satisfaction;&#xA;IF OBJECT_ID(N'dbo.stg_flight_activity') IS NOT NULL DROP TABLE dbo.stg_flight_activity;&#xA;IF OBJECT_ID(N'dbo.stg_customer_loyalty') IS NOT NULL DROP TABLE dbo.stg_customer_loyalty;&#xA;IF OBJECT_ID(N'dbo.stg_date') IS NOT NULL DROP TABLE dbo.stg_date;&#xA;-- Typed staging: satisfaction (with AvgServiceScore + Satisfaction_Flag pre-computed in transform)&#xA;CREATE TABLE dbo.stg_airline_satisfaction (&#xA;    stg_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;    ID INT, Gender NVARCHAR(20), Age INT, CustomerType NVARCHAR(50),&#xA;    TypeOfTravel NVARCHAR(50), Class NVARCHAR(50), FlightDistance INT,&#xA;    DepartureDelay INT NULL, ArrivalDelay INT NULL,&#xA;    TimeConvenience INT, OnlineBooking INT, CheckinService INT,&#xA;    OnlineBoarding INT, GateLocation INT, OnboardService INT,&#xA;    SeatComfort INT, LegRoom INT, Cleanliness INT, FoodAndDrink INT,&#xA;    InFlightService INT, InFlightWifi INT, InFlightEntertainment INT,&#xA;    BaggageHandling INT,&#xA;    AvgServiceScore DECIMAL(5,2),&#xA;    Satisfaction NVARCHAR(50),&#xA;    Satisfaction_Flag BIT&#xA;);&#xA;-- Typed staging: flight activity&#xA;CREATE TABLE dbo.stg_flight_activity (&#xA;    stg_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;    LoyaltyNumber NVARCHAR(50), Year INT, Month INT, TotalFlights INT,&#xA;    Distance DECIMAL(18,2), PointsAccumulated DECIMAL(18,2),&#xA;    PointsRedeemed DECIMAL(18,2), DollarCostPointsRedeemed DECIMAL(18,2)&#xA;);&#xA;-- Typed staging: customer loyalty&#xA;CREATE TABLE dbo.stg_customer_loyalty (&#xA;    stg_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;    LoyaltyNumber NVARCHAR(50), Country NVARCHAR(100), Province NVARCHAR(100),&#xA;    City NVARCHAR(100), PostalCode NVARCHAR(20), Gender NVARCHAR(20),&#xA;    Education NVARCHAR(100), Salary NVARCHAR(50), MaritalStatus NVARCHAR(50),&#xA;    LoyaltyCard NVARCHAR(50), CLV DECIMAL(18,2),&#xA;    EnrollmentType NVARCHAR(50), EnrollmentYear INT, EnrollmentMonth INT,&#xA;    CancellationYear INT NULL, CancellationMonth INT NULL&#xA;);&#xA;-- Typed staging: date&#xA;CREATE TABLE dbo.stg_date (&#xA;    stg_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;    DateValue DATE, StartOfYear DATE, StartOfQuarter DATE, StartOfMonth DATE&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Unknown_Members"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{AA000005-0000-4000-8000-AA0000000001}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Unknown_Members"
      DTS:TaskContact="Execute SQL Task"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AA000001-0000-4000-8000-AA0000000001}"
          SQLTask:SqlStatementSource="SET NOCOUNT ON;&#xA;USE [DWH_DB];&#xA;SET IDENTITY_INSERT dbo.DIM_DATE ON;&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_DATE WHERE SK_Date=-1)&#xA;    INSERT INTO dbo.DIM_DATE (SK_Date,DateValue,Year,Quarter,QuarterLabel,MonthNumber,MonthName,DayOfWeek,DayName,IsWeekend,StartOfYear,StartOfQuarter,StartOfMonth)&#xA;    VALUES (-1,NULL,0,0,N'Unknown',0,N'Unknown',0,N'Unknown',0,NULL,NULL,NULL);&#xA;SET IDENTITY_INSERT dbo.DIM_DATE OFF;&#xA;SET IDENTITY_INSERT dbo.DIM_LOYALTY_CARD ON;&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_LOYALTY_CARD WHERE SK_LoyaltyCard=-1)&#xA;    INSERT INTO dbo.DIM_LOYALTY_CARD (SK_LoyaltyCard,LoyaltyCard) VALUES (-1,N'Unknown');&#xA;SET IDENTITY_INSERT dbo.DIM_LOYALTY_CARD OFF;&#xA;SET IDENTITY_INSERT dbo.DIM_GEOGRAPHY ON;&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_GEOGRAPHY WHERE SK_Geography=-1)&#xA;    INSERT INTO dbo.DIM_GEOGRAPHY (SK_Geography,Country,Province,City,PostalCode)&#xA;    VALUES (-1,N'Unknown',N'Unknown',N'Unknown',N'Unknown');&#xA;SET IDENTITY_INSERT dbo.DIM_GEOGRAPHY OFF;&#xA;SET IDENTITY_INSERT dbo.DIM_TRAVEL ON;&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_TRAVEL WHERE SK_Travel=-1)&#xA;    INSERT INTO dbo.DIM_TRAVEL (SK_Travel,TypeOfTravel,Class,TravelProfile)&#xA;    VALUES (-1,N'Unknown',N'Unknown',N'Unknown');&#xA;SET IDENTITY_INSERT dbo.DIM_TRAVEL OFF;&#xA;SET IDENTITY_INSERT dbo.DIM_CUSTOMER ON;&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_CUSTOMER WHERE SK_Customer=-1)&#xA;    INSERT INTO dbo.DIM_CUSTOMER (SK_Customer,LoyaltyNumber,Gender,Education,Salary,MaritalStatus,CLV,EnrollmentType,EnrollmentYear,EnrollmentMonth,CancellationYear,CancellationMonth,IsChurned,SK_LoyaltyCard,SK_Geography,EnrollmentDate,SCD_StartDate,SCD_EndDate,SCD_IsCurrent)&#xA;    VALUES (-1,N'Unknown',N'Unknown',N'Unknown',N'Unknown',N'Unknown',0,N'Unknown',0,0,0,0,0,-1,-1,NULL,NULL,NULL,0);&#xA;SET IDENTITY_INSERT dbo.DIM_CUSTOMER OFF;&#xA;USE [STAGING_DB];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
